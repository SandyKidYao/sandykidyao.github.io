---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="关于 SandyKid" />
	</head>
	<body>
		<Header />

		<main class="wrap">
			<header class="page-head rise rise-1">
				<p class="kicker"><span class="sym">⌗</span>&nbsp; About</p>
				<h1>嗨，我是 <em>SandyKid</em>.</h1>
			</header>

			<section class="prose rise rise-2">
				<p>
					这里是我个人的笔记本——记录工作中关于 <strong>AI</strong>、<strong>编程</strong> 与
					<strong>软件工程</strong> 的一些思考和实践。
				</p>
				<p>
					不定期更新，写得慢，但希望每一篇都值得读完。
				</p>
				<p>
					偶尔可以在 <a href="https://github.com/SandyKidYao" target="_blank" rel="noopener">GitHub</a> 上找到我。
				</p>
			</section>
		</main>

		<Footer />

		<style>
			.page-head { padding-block: clamp(3rem, 8vw, 5rem) 2rem; }
			.kicker {
				font-family: var(--font-display);
				font-size: 0.85rem;
				color: var(--ink-3);
				letter-spacing: 0.16em;
				text-transform: uppercase;
				margin: 0 0 1.2rem;
			}
			.page-head h1 {
				font-family: var(--font-display);
				font-weight: 600;
				font-size: clamp(2.2rem, 5vw, 3.2rem);
				letter-spacing: -0.02em;
				margin: 0;
			}
			.page-head h1 em {
				font-style: italic;
				font-variation-settings: 'opsz' 144;
				color: var(--accent);
				font-weight: 500;
			}
			.prose {
				font-family: var(--font-body);
				font-size: 1.1rem;
				line-height: 1.75;
				color: var(--ink-2);
				font-variation-settings: 'opsz' 18, 'SOFT' 30;
			}
			.prose strong { color: var(--ink); }
		</style>
	</body>
</html>
