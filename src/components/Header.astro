---
const { pathname } = Astro.url;
const isActive = (href: string) =>
	href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
	<div class="wrap-wide bar">
		<a class="mark no-underline" href="/" aria-label="Home">
			<span class="mark-glyph">ᕕ( <span class="mark-eye">ᐛ</span> )ᕗ</span>
			<span class="mark-name">SK</span>
		</a>
		<nav aria-label="Primary">
			<a href="/" class:list={['nav-link no-underline', { active: isActive('/') }]}>Home</a>
			<a href="/blog" class:list={['nav-link no-underline', { active: isActive('/blog') }]}>Writing</a>
			<a href="/about" class:list={['nav-link no-underline', { active: isActive('/about') }]}>About</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		border-bottom: 1px solid var(--rule);
		background: var(--paper);
		position: sticky;
		top: 0;
		z-index: 10;
		backdrop-filter: saturate(180%) blur(8px);
	}
	.bar {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		padding-block: 1.1rem;
		gap: 1.5rem;
	}
	.mark {
		display: inline-flex;
		align-items: baseline;
		gap: 0.55rem;
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 0.95rem;
		color: var(--ink);
	}
	.mark-glyph {
		font-feature-settings: 'kern';
		color: var(--ink-2);
		letter-spacing: -0.02em;
	}
	.mark-eye { color: var(--accent); }
	.mark-name {
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
	nav {
		display: flex;
		gap: 1.4rem;
	}
	.nav-link {
		font-family: var(--font-display);
		font-size: 0.92rem;
		font-weight: 500;
		color: var(--ink-3);
		padding-block: 0.15rem;
		position: relative;
		transition: color 180ms ease;
	}
	.nav-link:hover { color: var(--ink); }
	.nav-link.active { color: var(--ink); }
	.nav-link.active::after {
		content: '';
		position: absolute;
		left: 0; right: 0; bottom: -2px;
		height: 1px;
		background: var(--accent);
	}
	@media (max-width: 480px) {
		.bar { padding-block: 0.9rem; gap: 1rem; }
		.mark-glyph { display: none; }
		nav { gap: 1rem; }
	}
</style>
